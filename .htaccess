# ============================================================
#  SkillLeo — Apache .htaccess
#  Hostinger shared hosting (Apache + mod_rewrite)
# ============================================================

Options -Indexes
Options -MultiViews

# ── Security headers ────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# ── Redirect root → website ──────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Remove www
    RewriteCond %{HTTP_HOST} ^www\.skillleo\.com [NC]
    RewriteRule ^(.*)$ https://skillleo.com/$1 [L,R=301]

    # Serve website from subfolder without changing URL
    # When root is requested, internally serve the website folder
    RewriteRule ^$ ui_kits/website/index.html [L]
    RewriteRule ^index\.html$ ui_kits/website/index.html [L]

    # Serve JSX/static files from website folder when referenced from root
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} \.(jsx|js)$
    RewriteRule ^([^/]+\.(jsx|js))$ ui_kits/website/$1 [L]
</IfModule>

# ── MIME types for JSX ──────────────────────────────────────
<IfModule mod_mime.c>
    AddType text/javascript .jsx
    AddType text/javascript .js
    AddType application/json .json
    AddType image/webp .webp
    AddType image/svg+xml .svg
    AddType application/manifest+json .webmanifest
</IfModule>

# ── Browser caching ─────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html "access plus 1 hour"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 6 months"
    ExpiresByType image/jpg "access plus 6 months"
    ExpiresByType image/jpeg "access plus 6 months"
    ExpiresByType image/gif "access plus 6 months"
    ExpiresByType image/webp "access plus 6 months"
    ExpiresByType image/svg+xml "access plus 6 months"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# ── Gzip compression ────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ── Custom error pages ──────────────────────────────────────
ErrorDocument 403 /ui_kits/website/index.html
ErrorDocument 404 /ui_kits/website/index.html
